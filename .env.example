# .env.example — documents every required env var. Copy to .env (gitignored) for
# local dev. In cloud, these are injected by the platform; never commit real values.
# Secrets via env only (CLAUDE.md golden rule #5).

# ─── Object storage — MinIO (local) / S3 (cloud) ────────────────────────────
# STORAGE_BACKEND selects the swap point: "local" (filesystem) or "s3" (S3/MinIO).
# Same ingestion code path either way; only this var + endpoint change.
STORAGE_BACKEND=s3
# When STORAGE_BACKEND=local, point at a directory of run.json/.jsonl + manifests:
LOCAL_SOURCE_DIR=./ingestion_sample
# AWS/MinIO credentials (MinIO defaults shown; real S3 omits S3_ENDPOINT_URL):
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
# Local MinIO endpoint as seen FROM THE HOST (make ingest/dbt run on the host).
# Airflow container overrides this to http://minio:9000 internally. Blank for real S3.
S3_ENDPOINT_URL=http://localhost:9000
# Landing zone is the only bucket — dashboard reads marts directly from Postgres (ADR-001).
S3_LANDING_BUCKET=rag-bench-landing
# Run files land under runs/ (may sit in dated batch subdirs, discovered recursively).
S3_LANDING_PREFIX=runs/
# Shared reference inputs (questions.jsonl + corpus profiles) — not run-scoped.
S3_REFERENCE_PREFIX=reference/

# ─── Analytics warehouse — Postgres ─────────────────────────────────────────
# Host-run tooling (make ingest/dbt) reaches Postgres at localhost (compose maps 5432).
# Airflow container overrides POSTGRES_HOST to 'postgres' internally.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics
# Schemas: raw landing zone vs dbt build target.
RAW_SCHEMA=raw
DBT_SCHEMA=analytics

# ─── dbt ────────────────────────────────────────────────────────────────────
# Selects local vs cloud target in profiles.yml. Same models everywhere.
DBT_TARGET=local

# ─── Dashboard — Streamlit ───────────────────────────────────────────────────
# Least-privilege read-only role for the marts schema (golden rule #2 / ADR-001).
# Provisioned idempotently by dbt on-run-end (macros/grant_marts_reader.sql).
MARTS_READER_USER=marts_reader
MARTS_READER_PASSWORD=marts_reader

# ─── Orchestrator — Airflow ──────────────────────────────────────────────────
# Separate Postgres instance from the analytics warehouse (different host in prod).
# Only used when running: docker compose --profile airflow up
AIRFLOW_DB=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
# UI admin login. The compose command pre-creates this admin user before
# `airflow standalone` (which would otherwise mint a random password). Username
# must stay "admin" to match standalone's check. Cloud: inject via secrets manager.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
