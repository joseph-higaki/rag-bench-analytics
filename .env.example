# .env.example — documents every required env var. Copy to .env (gitignored) for
# local dev. In cloud, these are injected by the platform; never commit real values.
# Secrets via env only (CLAUDE.md golden rule #5).

# ─── Object storage (the landing zone) ──────────────────────────────────────
# STORAGE_BACKEND selects the swap point: "local" (a directory) or "s3" (S3/MinIO).
# Same ingestion code path either way; only this var + endpoint change.
STORAGE_BACKEND=s3

# When STORAGE_BACKEND=local, point at a directory of run.json/.jsonl + manifests:
LOCAL_SOURCE_DIR=./ingestion_sample

# When STORAGE_BACKEND=s3 (local MinIO defaults shown; real S3 omits ENDPOINT_URL):
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
# Local MinIO endpoint as seen FROM THE HOST (make ingest/dbt run on the host).
# The Airflow container overrides this to http://minio:9000 internally. Blank for real S3.
S3_ENDPOINT_URL=http://localhost:9000
# Bucket: the landing zone is the only object-storage role — the dashboard reads marts
# directly from Postgres (no Parquet export).
S3_LANDING_BUCKET=rag-bench-landing
S3_LANDING_PREFIX=runs/

# ─── Warehouse (Postgres) ───────────────────────────────────────────────────
# Host-run tooling (make ingest/dbt) reaches Postgres at localhost (compose maps
# 5432). The Airflow container overrides POSTGRES_HOST to 'postgres' internally.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics
# Schemas: raw landing zone vs dbt build target.
RAW_SCHEMA=raw
DBT_SCHEMA=analytics

# ─── Dashboard (read-only marts access) ─────────────────────────────────────
# Streamlit connects directly to the <DBT_SCHEMA>_marts schema as a least-privilege
# read-only role (golden rule #2 / ADR-001), provisioned idempotently by dbt on-run-end
# (macros/grant_marts_reader.sql). Local default mirrors the analytics/analytics posture;
# cloud injects a real secret.
MARTS_READER_USER=marts_reader
MARTS_READER_PASSWORD=marts_reader

# ─── Airflow metadata DB ────────────────────────────────────────────────────
# Separate Postgres instance from the analytics warehouse (different host in prod,
# different container locally). Only used when running the airflow profile.
AIRFLOW_DB=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# ─── dbt ────────────────────────────────────────────────────────────────────
# Selects local vs cloud target in profiles.yml. Same models everywhere.
DBT_TARGET=local
