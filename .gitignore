# Secrets & local env
.env
*.env
!.env.example
secrets/

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.ruff_cache/
*.egg-info/

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/
profiles.yml
!dbt/profiles.example.yml

# Data artifacts (fixtures in ingestion_sample/ ARE committed; everything else is not)
*.parquet
exports/
minio-data/
postgres-data/

# Ingestion run batches are local pipeline outputs: keep ONE committed as the sample
# fixture, ignore the rest (incl. future dated batches). reference/ (shared inputs read
# at transform time) stays tracked; older already-committed batches remain but take no
# new files. Negation works because the parent ingestion_sample/ is not itself ignored.
ingestion_sample/*/
!ingestion_sample/reference/
!ingestion_sample/20260627T091002Z/

# Terraform
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.*
infra/*.tfvars
!infra/*.tfvars.example

# Claude Code local settings (personal; the project .claude/CLAUDE.md IS tracked)
.claude/settings.local.json
